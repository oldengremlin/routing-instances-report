<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout>
                <Pattern>%d{HH:mm:ss.SSS} %-5level [%c{1}] %msg%n%throwable</Pattern>
            </PatternLayout>
        </Console>
    </Appenders>
    <Loggers>
        <!-- Suppress verbose SSH negotiation noise from JSch -->
        <Logger name="com.jcraft" level="warn" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Root level="${env:LOG_LEVEL:-info}">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
